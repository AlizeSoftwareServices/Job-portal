generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CANDIDATE
}

enum JobStatus {
  ACTIVE
  HIDDEN
  COMPLETED
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
}

enum InterviewType {
  GOOGLE_MEET
  ZOOM
  MICROSOFT_TEAMS
  OFFICE_VISIT
}

model User {
  id             String            @id @default(uuid())
  email          String            @unique
  passwordHash   String
  role           Role              @default(CANDIDATE)
  firstName      String?
  lastName       String?
  countryCode    String?
  phone          String?
  isVerified     Boolean           @default(false)
  refreshToken   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  candidateProfile CandidateProfile?
  applications   Application[]
  jobsCreated    Job[]             @relation("JobsCreatedByAdmin")
}

model CandidateProfile {
  id               String            @id @default(uuid())
  userId           String            @unique
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName         String
  phone            String?
  address          String?
  summary          String?
  avatarUrl        String?
  resumeUrl        String?           // Local path URL
  expectedSalary   String?
  preferredLocation String?
  preferredJobType String?

  experiences      Experience[]
  educations       Education[]
  skills           Skill[]
  certifications   Certification[]
  projects         Project[]
}

model Experience {
  id               String            @id @default(uuid())
  profileId        String
  profile          CandidateProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company          String
  title            String
  startDate        DateTime
  endDate          DateTime?
  description      String?
}

model Education {
  id               String            @id @default(uuid())
  profileId        String
  profile          CandidateProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution      String
  degree           String
  fieldOfStudy     String?
  startDate        DateTime
  endDate          DateTime?
}

model Skill {
  id               String            @id @default(uuid())
  profileId        String
  profile          CandidateProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name             String
}

model Certification {
  id               String            @id @default(uuid())
  profileId        String
  profile          CandidateProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name             String
  issuer           String
  dateIssued       DateTime?
}

model Project {
  id               String            @id @default(uuid())
  profileId        String
  profile          CandidateProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  link             String?
}

model Job {
  id               String            @id @default(uuid())
  jobCode          String            @unique
  title            String
  department       String?
  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locationCity     String
  locationState    String
  locationCountry  String            @default("India")
  salaryMin        Int?
  salaryMax        Int?
  experienceLevel  String            // e.g., "Fresher", "1-3 Years"
  workMode         String            // e.g., "Remote", "Onsite"
  jobType          String            // e.g., "Full Time", "Contract"
  description      String
  requirements     String
  benefits         String?
  skills           String[]          // Array of skills required
  educationReq     String?
  vacancyCount     Int               @default(1)
  status           JobStatus         @default(ACTIVE)
  expiryDate       DateTime?
  visibilityStatus Boolean           @default(true)
  salary           String?
  salaryType       String?           @default("Month")
  salaryVisible    Boolean           @default(true)
  
  facebookLink     String?
  instagramLink    String?
  linkedinLink     String?

  createdByAdminId String
  createdByAdmin   User              @relation("JobsCreatedByAdmin", fields: [createdByAdminId], references: [id])
  
  applications     Application[]
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Application {
  id               String            @id @default(uuid())
  candidateId      String?
  candidate        User?             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId            String?
  job              Job?              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  referenceNumber  String?           @unique
  
  // Detailed application fields (Adecco style)
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  noticePeriod     String?
  street           String?
  city             String?
  state            String?
  country          String?
  zipCode          String?

  resumeUrl        String?           // Local path URL specifically for this application
  status           ApplicationStatus @default(APPLIED)
  adminRating      Int?              // 1 to 5 stars
  adminNotes       String?
  isReviewed       Boolean           @default(false)
  
  interview        Interview?
  
  appliedAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // We can't strictly enforce unique constraints on guest applications this simply,
  // but if candidateId is present, we could. For now, removing the strict compound unique
  // to allow multiple guest applications or we can rely on application-level checks.
  // @@unique([candidateId, jobId])
}

model Interview {
  id               String            @id @default(uuid())
  applicationId    String            @unique
  application      Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  
  date             DateTime
  time             String
  type             InterviewType
  meetingLink      String?
  notes            String?
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Category {
  id               String            @id @default(uuid())
  name             String            @unique
  imageUrl         String?
  
  jobs             Job[]
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String   // e.g., 'REGISTER', 'FORGOT_PASSWORD'
  expiresAt DateTime
  createdAt DateTime @default(now())
}
